---
import { getPageAST } from '../utils/contentProvider.js';
import { fetchAsset } from '../utils/assetFetcher.js';
import { renderTemplate } from '../utils/renderer.js';

// Retrieve slug and query parameters
const { slug } = Astro.params;
const branch = Astro.url.searchParams.get('branch') || undefined;

// Measure performance for our audit log
const startTime = performance.now();

const IMAGE_OPTIMIZER_URL = process.env.IMAGE_OPTIMIZER_URL || 'http://localhost:3002';
const urlsToPreWarm: string[] = [];

// Image optimization helper (routes external JPEGs/PNGs through separate microservice)
function optimizeImageUrl(url: string, width: number = 800): string {
  if (!url) return '';
  const trimmed = url.trim();
  if (trimmed.startsWith('/') || trimmed.endsWith('.svg') || trimmed.includes(IMAGE_OPTIMIZER_URL)) {
    return trimmed;
  }
  const optUrl = `${IMAGE_OPTIMIZER_URL}/?url=${encodeURIComponent(trimmed)}&w=${width}&q=80`;
  urlsToPreWarm.push(optUrl);
  return optUrl;
}

// Generate responsive srcset attribute matching microservice widths
function generateSrcset(url: string, widths: number[]): string {
  if (!url) return '';
  const trimmed = url.trim();
  if (trimmed.startsWith('/') || trimmed.endsWith('.svg')) {
    return '';
  }
  return widths
    .map((w) => {
      const optUrl = `${IMAGE_OPTIMIZER_URL}/?url=${encodeURIComponent(trimmed)}&w=${w}&q=80`;
      urlsToPreWarm.push(optUrl);
      return `${optUrl} ${w}w`;
    })
    .join(', ');
}

// 1. Fetch Page Content AST (Stale-While-Revalidate Edge Cache)
const pageContent = await getPageAST(slug || '');
const { metadata, blocks } = pageContent;

// Extract Largest Contentful Paint (LCP) image from the first block for preloading
const firstBlock = blocks?.[0];
let lcpImageUrl = '';
let lcpImageSrcset = '';
if (firstBlock && firstBlock.type.toUpperCase() === 'HERO' && firstBlock.data?.backgroundImage) {
  lcpImageUrl = optimizeImageUrl(firstBlock.data.backgroundImage, 1400);
  lcpImageSrcset = generateSrcset(firstBlock.data.backgroundImage, [480, 800, 1200, 1600, 2000]);
}

// 2. State storage for request-time dynamic composition
let renderedHtml = '';
const loadedCss = new Set<string>();
const loadedJs = new Set<string>();
let aggregatedCss = '';
let aggregatedJs = '';
const jsonLdSchemas: any[] = [];

// Fetch global design system index.css from CDN (utilizing the SWR cache)
let globalCss = '';
try {
  globalCss = await fetchAsset('index.css', branch);
} catch (e: any) {
  console.error('[Renderer] Failed to fetch global index.css from CDN:', e.message);
}

// 3. Loop through blocks and stitch HTML, CSS, and JS components
for (const block of blocks) {
  const { type } = block;
  const data = { ...block.data };

  try {
    // A. Fetch HTML layout from Edge CDN
    const htmlTemplate = await fetchAsset(`${type}.html`, branch);
    
    // Optimize block images dynamically at request-time
    if (type.toUpperCase() === 'HERO' && data.backgroundImage) {
      data.backgroundImageSrcset = generateSrcset(data.backgroundImage, [480, 800, 1200, 1600, 2000]);
      data.backgroundImage = optimizeImageUrl(data.backgroundImage, 1400);
    } else if (type.toUpperCase() === 'TWOCOLUMN' && data.image) {
      data.imageSrcset = generateSrcset(data.image, [400, 600, 800, 1200]);
      data.image = optimizeImageUrl(data.image, 800);
    } else if (type.toUpperCase() === 'STUDIOCARDS' && Array.isArray(data.items)) {
      data.items = data.items.map((item: any) => ({
        ...item,
        imageSrcset: generateSrcset(item.image, [300, 450, 600, 900]),
        image: optimizeImageUrl(item.image, 450)
      }));
    }

    // B. Interpolate variables and append to page body
    const blockHtml = renderTemplate(htmlTemplate, data);
    renderedHtml += `\n<!-- Block: ${type} -->\n${blockHtml}`;

    // C. Fetch and cache CSS stylesheet (deduplicated)
    if (!loadedCss.has(type)) {
      try {
        const cssContent = await fetchAsset(`${type}.css`, branch);
        aggregatedCss += `\n/* Component: ${type} */\n${cssContent}`;
        loadedCss.add(type);
      } catch (e) {
        // Optional CSS: component might use global styles only
        console.log(`[Renderer] No style file found for block "${type}"`);
      }
    }

    // D. Fetch optional client-side Vanilla JS script (deduplicated)
    if (!loadedJs.has(type)) {
      try {
        const jsContent = await fetchAsset(`${type}.js`, branch);
        aggregatedJs += `\n/* Script: ${type} */\n${jsContent}`;
        loadedJs.add(type);
      } catch (e) {
        // Optional JS: component might be static
        console.log(`[Renderer] No script file found for block "${type}"`);
      }
    }

    // E. Dynamic Structured Data (JSON-LD) Generation
    if (type.toUpperCase() === 'FAQ') {
      const faqItems = data.items || [];
      const schema = {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map((item: any) => ({
          "@type": "Question",
          "name": item.question || '',
          "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer || ''
          }
        }))
      };
      jsonLdSchemas.push(schema);
    } else if (type.toUpperCase() === 'HOWTO') {
      const steps = data.items || [];
      const schema = {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": data.sectionTitle || 'Instructional Guide',
        "step": steps.map((item: any, index: number) => ({
          "@type": "HowToStep",
          "position": index + 1,
          "name": item.title || `Step ${index + 1}`,
          "text": item.description || ''
        }))
      };
      jsonLdSchemas.push(schema);
    }
  } catch (err: any) {
    console.error(`[Renderer] Error rendering block "${type}":`, err.message);
    renderedHtml += `\n<div style="padding: 2rem; background: #fee2e2; color: #b91c1c; border: 1px solid #f87171; margin: 1rem 0; border-radius: 4px;">Error rendering block "${type}": ${err.message}</div>`;
  }
}

// Asynchronously pre-warm the image optimizer cache for all collected image URLs
if (urlsToPreWarm.length > 0) {
  const INTERNAL_IMAGE_OPTIMIZER_URL = process.env.INTERNAL_IMAGE_OPTIMIZER_URL || 'http://image-optimizer:3002';
  urlsToPreWarm.forEach(url => {
    const internalUrl = url.replace(IMAGE_OPTIMIZER_URL, INTERNAL_IMAGE_OPTIMIZER_URL);
    fetch(internalUrl).catch(() => {});
  });
}

// Measure composition performance
const durationMs = performance.now() - startTime;
Astro.response.headers.set('X-Response-Time', `${durationMs.toFixed(2)}ms`);
console.log(`[Render Engine] Dynamic page rendered in ${durationMs.toFixed(2)}ms`);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- Primary SEO Meta Tags -->
  <title>{metadata.title || "Globant Document Platform"}</title>
  
  <!-- Dynamic Meta Injection (SEO, OG, Geo) -->
  {Object.entries(metadata).map(([key, value]) => {
    if (key === 'title' || key === 'theme') return null; // already handled
    
    // OpenGraph tags use property attribute
    if (key.startsWith('og:')) {
      return <meta property={key} content={value} />;
    }
    // Geo position, region, and standard meta tags
    return <meta name={key} content={value} />;
  })}

  <!-- Preconnect to Image Optimizer and Font CDNs -->
  <link rel="preconnect" href={IMAGE_OPTIMIZER_URL} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  {lcpImageUrl && (
    <link 
      rel="preload" 
      as="image" 
      href={lcpImageUrl} 
      imagesrcset={lcpImageSrcset} 
      imagesizes="100vw" 
      fetchpriority="high" 
    />
  )}

  <!-- Asynchronously load Heebo Font CSS (Non-blocking CRP Optimization) -->
  <link 
    rel="preload" 
    as="style" 
    href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap" 
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&display=swap" />
  </noscript>

  <!-- Global design system stylesheet (fetched from CDN and inlined for rendering speed) -->
  {globalCss && <style set:html={globalCss}></style>}

  <!-- Dynamic Compiled Aggregated CSS (Inlined for 100/100 LCP Performance) -->
  {aggregatedCss && <style set:html={aggregatedCss}></style>}

  <!-- Dynamic JSON-LD Structured Data Injection -->
  {jsonLdSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body class={metadata.theme === 'dark' ? 'dark-theme' : 'light-theme'}>
  
  <!-- Header / Navigation Shell — faithful replica of globant.com nav -->
  <header style="
    position: sticky;
    top: 0;
    z-index: 200;
    background-color: #000000;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 0;
  ">
    <div class="container" style="
      display: flex;
      justify-content: space-between;
      align-items: center;
      height: 72px;
    ">
      <!-- Globant wordmark with lime-green ► arrow (matches real site logo) -->
      <a href="/" aria-label="Globant home" style="
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        flex-shrink: 0;
      ">
        <span style="
          font-family: 'Heebo', sans-serif;
          font-size: 2.2rem;
          font-weight: 900;
          color: #ffffff;
          letter-spacing: -0.02em;
          line-height: 1;
        ">Globant</span>
        <!-- Lime-green play/arrow icon matching real Globant logo -->
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="4,2 18,10 4,18" fill="#c3d500"/>
        </svg>
      </a>

      <!-- Primary nav — matches globant.com main navigation items -->
      <nav aria-label="Main navigation">
        <ul style="
          display: flex;
          align-items: center;
          gap: 0.4rem;
          list-style: none;
          font-family: 'Heebo', sans-serif;
          font-size: 1.4rem;
          font-weight: 700;
        ">
          <li><a href="/our-offering" style="
            color: rgba(255,255,255,0.85);
            padding: 0.8rem 1.2rem;
            border-radius: 6px;
            transition: color 0.18s, background 0.18s;
            display: block;
          " onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">Our Offering</a></li>
          <li><a href="/about" style="
            color: rgba(255,255,255,0.85);
            padding: 0.8rem 1.2rem;
            border-radius: 6px;
            transition: color 0.18s;
            display: block;
          " onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">About</a></li>
          <li><a href="/insights" style="
            color: rgba(255,255,255,0.85);
            padding: 0.8rem 1.2rem;
            border-radius: 6px;
            transition: color 0.18s;
            display: block;
          " onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">Insights</a></li>
          <li><a href="/careers" style="
            color: rgba(255,255,255,0.85);
            padding: 0.8rem 1.2rem;
            border-radius: 6px;
            transition: color 0.18s;
            display: block;
          " onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.85)'">Careers</a></li>
          <li><a href="/contact" style="
            display: block;
            margin-left: 0.8rem;
            padding: 0.9rem 2rem;
            background: #c3d500;
            color: #000000;
            font-weight: 800;
            font-size: 1.4rem;
            border-radius: 50px;
            transition: background 0.18s, box-shadow 0.18s;
          " onmouseover="this.style.background='#d4e800'; this.style.boxShadow='0 4px 16px rgba(195,213,0,0.35)'" onmouseout="this.style.background='#c3d500'; this.style.boxShadow='none'">Contact Us</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <!-- Page Main Content Body -->
  <main>
    <Fragment set:html={renderedHtml} />
  </main>

  <!-- Footer Shell — globant.com-style dark footer -->
  <footer style="
    background-color: #000000;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 6rem 0 3rem;
    font-family: 'Heebo', sans-serif;
  ">
    <div class="container">
      <!-- Footer top: logo + columns -->
      <div style="
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 4rem;
        margin-bottom: 5rem;
      ">
        <!-- Brand column -->
        <div>
          <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.6rem;">
            <span style="font-size: 2.2rem; font-weight: 900; color: #fff; letter-spacing: -0.02em;">Globant</span>
            <svg width="16" height="16" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><polygon points="4,2 18,10 4,18" fill="#c3d500"/></svg>
          </div>
          <p style="color: rgba(255,255,255,0.5); font-size: 1.4rem; line-height: 1.65; max-width: 300px;">
            Engineering digital transformations for global companies, from startups to Fortune 500.
          </p>
        </div>
        <!-- Links column 1 -->
        <div>
          <p style="color: #c3d500; font-size: 1.1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1.6rem;">Company</p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 1rem;">
            <li><a href="/about" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">About Us</a></li>
            <li><a href="/careers" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">Careers</a></li>
            <li><a href="/investors" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">Investors</a></li>
          </ul>
        </div>
        <!-- Links column 2 -->
        <div>
          <p style="color: #c3d500; font-size: 1.1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1.6rem;">Services</p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 1rem;">
            <li><a href="/our-offering" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">Our Offering</a></li>
            <li><a href="/insights" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">Insights</a></li>
            <li><a href="/contact" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">Contact Us</a></li>
          </ul>
        </div>
        <!-- Links column 3 -->
        <div>
          <p style="color: #c3d500; font-size: 1.1rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.15em; margin-bottom: 1.6rem;">Follow Us</p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 1rem;">
            <li><a href="https://linkedin.com/company/globant" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">LinkedIn</a></li>
            <li><a href="https://twitter.com/globant" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">X (Twitter)</a></li>
            <li><a href="https://youtube.com/globant" style="color: rgba(255,255,255,0.6); font-size: 1.4rem; transition: color 0.18s;" onmouseover="this.style.color='#c3d500'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">YouTube</a></li>
          </ul>
        </div>
      </div>

      <!-- Footer bottom: copyright + legal -->
      <div style="
        border-top: 1px solid rgba(255,255,255,0.1);
        padding-top: 2.4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.2rem;
      ">
        <p style="color: rgba(255,255,255,0.4); font-size: 1.3rem;">&copy; {new Date().getFullYear()} Globant. All rights reserved.</p>
        <p style="color: rgba(255,255,255,0.3); font-size: 1.2rem;">Powered by Zero-Compile Edge Composition — POC</p>
      </div>
    </div>
  </footer>

  <!-- Dynamic Compiled Client-Side Interactivity Script -->
  {aggregatedJs && <script type="text/javascript" set:html={aggregatedJs}></script>}
</body>
</html>

<style is:global>
  /* Global Page Layout Theme overrides */
  .dark-theme {
    background-color: var(--color-bg-dark);
    color: var(--color-text-primary);
  }
  .light-theme {
    background-color: #ffffff;
    color: #111827;
    --color-bg-card: #f3f4f6;
    --color-border: #e5e7eb;
    --color-text-primary: #111827;
    --color-text-secondary: #4b5563;
  }
</style>
